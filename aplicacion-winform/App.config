<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8.1" />
    </startup>
    <appSettings>
        <add key="images-folder" value="c:\art-app\"/>
    </appSettings>
    <connectionStrings>
        <add name="CatalogoDB" connectionString="server=.\SQLEXPRESS; database=CATALOGO_P3_DB; integrated security=true" providerName="System.Data.SqlClient" />
    </connectionStrings>
</configuration>